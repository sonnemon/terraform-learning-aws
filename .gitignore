# Terraform — the state stores EVERYTHING in plain text, never commit it
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl.backup
crash.log
override.tf
override.tf.json

# Sensitive variable files (commit only non-sensitive examples like dev.tfvars.example)
*.auto.tfvars
secrets.tfvars

# Node
node_modules/
dist/

# Lambda zips — rebuilt from source on every plan, no reason to commit them
build/

# Credentials — never commit
.env
.env.*

# Editor / OS
.vscode/
.idea/
.DS_Store
